[Unit]
Description=OCTA X11/Xvfb bootstrap
After=default.target

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=%h/.config/octa/env
WorkingDirectory=${OCTA_REPO}
ExecStart=/usr/bin/env bash scripts/octa_systemd_entrypoint.sh
ExecStart=/usr/bin/env bash scripts/octa_x11_bootstrap.sh
Restart=always
RestartSec=2
StartLimitIntervalSec=0
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=octa.target
