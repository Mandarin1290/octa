[Unit]
Description=OCTA IBKR X11 popup autologin watcher
After=octa-x11.service octa-ibkr.service
Wants=octa-x11.service octa-ibkr.service

[Service]
Type=simple
EnvironmentFile=%h/.config/octa/env
WorkingDirectory=${OCTA_REPO}
ExecStart=/usr/bin/env bash scripts/octa_autologin_bootstrap.sh
Restart=always
RestartSec=2
StartLimitIntervalSec=0
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=octa.target
