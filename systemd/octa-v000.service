[Unit]
Description=OCTA v000 loop
After=octa-autologin.service
Wants=octa-autologin.service

[Service]
Type=simple
EnvironmentFile=%h/.config/octa/env
Environment=OCTA_XVFB_DISPLAY=:99
Environment=DISPLAY=:99
WorkingDirectory=${OCTA_REPO}
ExecStart=/usr/bin/env bash scripts/octa_v000_loop.sh
Restart=always
RestartSec=2
StartLimitIntervalSec=0
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=octa.target
